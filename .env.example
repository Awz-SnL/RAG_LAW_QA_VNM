# ─── LLM Provider (chọn 1): "glm" | "gemini" | "openai" ─────────────────────
LLM_PROVIDER=glm

# GLM – VNPay AI Gateway (nội bộ VNPay)
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://genai.vnpay.vn/aigateway/llm_glm47/v1/
LLM_MODEL_GLM=glm-4.7-flash

# Google Gemini (miễn phí): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (trả phí): https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Embedding model ──────────────────────────────────────────────────────────
# Các lựa chọn:
#   keepitreal/vietnamese-sbert                     ← Mặc định, ~270MB, nhanh
#   VoVanPhuc/sup-SimCSE-VietNamese-phobert-base    ← PhoBERT, ~540MB, chất lượng cao
#   intfloat/multilingual-e5-large                  ← Đa ngôn ngữ, ~1.1GB
EMBEDDING_MODEL=keepitreal/vietnamese-sbert

# ─── Vector Database ──────────────────────────────────────────────────────────
COLLECTION_NAME=vnqa_documents

# ─── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=50

# ─── Retrieval ────────────────────────────────────────────────────────────────
TOP_K=5
